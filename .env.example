# Supabase — crie um projeto em https://supabase.com/dashboard e pegue esses valores em
# Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-anon-key-publica

# Anthropic — crie uma chave em https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...
# Opcional: troque o modelo usado pelos agentes (padrão: claude-sonnet-4-5)
# ANTHROPIC_MODEL=claude-sonnet-4-5
